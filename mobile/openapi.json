        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "sequence": {
            "type": "integer",
            "title": "Sequence"
          },
          "race_name": {
            "type": "string",
            "title": "Race Name"
          },
          "race_date": {
            "type": "string",
            "format": "date",
            "title": "Race Date"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "title": "Start Date"
          },
          "end_date": {
            "type": "string",
            "format": "date",
            "title": "End Date"
