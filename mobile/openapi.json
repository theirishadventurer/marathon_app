      "CompletedWorkoutOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "garmin_activity_id": {
            "type": "integer",
            "title": "Garmin Activity Id"
          },
          "activity_date": {
            "type": "string",
            "format": "date",
            "title": "Activity Date"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "title": "Started At"
          },
          "activity_type": {
            "type": "string",
            "title": "Activity Type"
          },
          "family": {
            "type": "string",
            "title": "Family"
          },
          "duration_s": {
            "type": "integer",
            "title": "Duration S"
          },
          "distance_m": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Distance M"
          },
          "avg_hr": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Avg Hr"
          },
          "max_hr": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Hr"
          },
          "avg_pace_s_per_km": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Avg Pace S Per Km"
          },
          "elevation_gain_m": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Elevation Gain M"
          },
          "calories": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Calories"
          }
        },
        "type": "object",
        "required": [
          "id",
          "garmin_activity_id",
          "activity_date",
          "started_at",
          "activity_type",
          "family",
          "duration_s",
          "distance_m",
          "avg_hr",
          "max_hr",
          "avg_pace_s_per_km",
          "elevation_gain_m",
          "calories"
        ],
        "title": "CompletedWorkoutOut"
      },
